# Forçar LF para todos os arquivos texto — evita corrupção de UTF-8 no Windows
* text=auto eol=lf
*.html text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.svg text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Binários — sem conversão
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.webp binary
